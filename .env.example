# Shoonya API Credentials
# Copy this file to .env and fill in your actual values.
# The .env file must sit in the same folder as SpreadTrader.exe on Windows.

SHOONYA_USER_ID=your_user_id
SHOONYA_PASSWORD=your_password
SHOONYA_API_KEY=your_api_key
SHOONYA_TOTP_SECRET=your_base32_totp_secret
SHOONYA_VENDOR_CODE=your_vendor_code
SHOONYA_IMEI=your_imei

# Report export directory (Windows path, use forward slashes or double backslashes)
REPORTS_DIR=C:/SpreadTrader/Reports
